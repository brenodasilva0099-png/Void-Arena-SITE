# ===============================
# VOID ARENA / ABYSS TOURMENT GAME
# Configuração local
# ===============================

PORT=3001
SESSION_SECRET=troque-por-uma-chave-grande-e-aleatoria

# Bot Discord
DISCORD_TOKEN=COLE_SEU_TOKEN_NOVO_AQUI
CLIENT_ID=COLE_SEU_APPLICATION_ID_AQUI

# Login Discord
DISCORD_CLIENT_ID=COLE_SEU_APPLICATION_ID_AQUI
DISCORD_CLIENT_SECRET=COLE_SEU_CLIENT_SECRET_NOVO_AQUI
DISCORD_CALLBACK_URL=http://localhost:3000/auth/discord/callback

# Administrador do painel (opcional)
ADMIN_DISCORD_IDS=
ADMIN_EMAILS=
ADMIN_USER_IDS=

# Split Site/Bot
# URL interna do bot separado. Local padrão:
BOT_API_URL=http://localhost:3002
# Use o mesmo token também no ZIP do bot se quiser proteger a ponte interna.
BOT_API_KEY=
# Opção 2: o banco fica no BOT. O SITE acessa via BOT_API_URL + BOT_API_KEY.
# Não precisa configurar DATA_DIR no SITE em produção.
